# Copie para .env (que esta no .gitignore) e ajuste conforme o ambiente.

# Conexao com o banco. Se ausente, o codigo usa o Postgres local do docker-compose:
#   postgresql+psycopg2://treasury:localdev@localhost:5432/stable_treasury
# Em producao (Streamlit Cloud + Supabase/Neon), defina a connection string real aqui.
DATABASE_URL=postgresql+psycopg2://treasury:localdev@localhost:5432/stable_treasury

# Opcional: chave Etherscan/PolygonScan para gas fee real (senao usa fallback de gwei).
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
